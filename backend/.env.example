# Database
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/libragold"

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@libragoldgroup.com

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://libragoldgroup.com
